    raise ValueError('AGENT_IP env var not provided.')


ELF_MAGIC = b"\x7F\x45\x4C\x46"
SHEBANG_MAGIC = b"\x23\x21"

background_tasks = set()
def start_as_background_task(loop, fun):
    task = loop.create_task(fun)
    background_tasks.add(task)
    task.add_done_callback(background_tasks.discard)

class HandleInternalMessages(asyncio.Protocol):
    sk = None
    runner = None
    logger = None

    def __init__(self, runner):
        self.runner = runner
        self.logger = self.runner._logger
    
    def connection_made(self, transport):
        self.sk = transport
        self.logger.info("Peer process connected.")

    def connection_closed(self, exc):
        self.logger.info("Internal channel closed. Stopping loops.")
        self.runner.on_close.set_result(True)

    def data_received(self, data: bytes):
        try:
            msg = _InternalMsgBase.deserialize(data)
            self.handle_msg(msg)
        except Exception as e:
            self.logger.exception(f'Failed to parse Internal data: {e}. Ignoring...')

    def handle_msg(self, msg: _InternalMsgBase):
        self.logger.info(f"rx Internal: Handling {msg}")
        if msg.type == InternalMsgType.Done:
            if msg.token == self.runner.token:
                self.sk.close()
                self.connection_closed(None)
            else:
                self.logger.warning('Unauthenticated done request!!')
        elif msg.type == InternalMsgType.ProxyToAgent:
            # Sanity check: try parsing proxied message to ensure correctness.
            try:
                submsg = _MsgBase.from_dict(msg.msg)
            except Exception as e:
                self.logger.exception(f'Failed to load proxied message: {e}. Ignoring...')
                return

            # Sanity check: only Student messages can be proxied to Agent.
            if not submsg.is_student():
                self.logger.warning(f'Proxied message is not a student type: {submsg.type}. Ignoring...')
                return
            
            # If msg is a request to create the student container, and the socket is free,
            # register student socket_id
            if submsg.type == MsgType.StudentRun and submsg.socket_id not in self.runner.running_student_container:
                with self.runner.lock:
                    self.runner.running_student_container[submsg.socket_id] = self.sk

            # Proxy msg to Agent.
            self.runner.agent.write(submsg.serialize())
        else:
            self.logger.warning(f'Unexpected internal message {msg.type}. Ignoring...')


class HandleAgentMessages(asyncio.Protocol):
    sk = None
    logger = None
    runner = None

    def __init__(self, runner):
        self.runner = runner
        self.logger = self.runner._logger

    def connection_made(self, transport):
        # We accept a single connection from the Agent.
        # TODO: Authenticate connection?
        if self.sk is not None:
            self.logger.info('Ignoring unexpected connection request.')
        else:
            self.sk = transport
            self.runner.agent = self.sk
            self.logger.info("Connected to Agent.")

    def data_received(self, data: bytes):
        try:
            msg = _MsgBase.deserialize(data)
            try:
                self.handle_msg(msg)
            except Exception as e:
                self.logger.exception(f'Failed to handle Agent message: {e}')
                self.sk.write(GradingError(str(e)).serialize())
                self.sk.close()
                self.runner.on_close.set_result(False)
        except Exception as e:
            self.logger.warning(f'Failed to parse Agent data: {e}. Ignoring...')

    def handle_msg(self, msg: _MsgBase):
        self.logger.info(f"rx Agent: Handling {msg}")
        if msg.type == MsgType.AgentInitMsg:
            start_as_background_task(self.runner._loop, self.runner.start_cmd(msg))
        elif msg.is_student():
            self.handle_student_msg(msg)
        else:
            raise TypeError("Unexpected message type. Ignoring..")

    def handle_student_msg(self, msg: _StudentBase):
        with self.runner.lock:
            channel = self.runner.running_student_container.get(msg.socket_id)

        if channel is None:
            raise ValueError(f"Received a message from agent for student container at {msg.socket_id} but its is not registered...")
        
        if msg.type == MsgType.StudentRetVal:
            # Cleanup terminated student container state
            with self.runner.lock:
                del self.runner.running_student_container[msg.socket_id]
        elif msg.type == MsgType.StudentStarted:
            # Expected message.
            pass
        else:
            # Unexpected messages.
            self.logger.warning(f"Received unexpected student container message {msg.type}. Ignoring..")
            return

        channel.write(msg.serialize())

class INGIniousMainRunner:
    def __init__(self):

        # Setup logger
        logger = logging.getLogger("inginious")
        logger.setLevel(logging.DEBUG)
        ch = logging.StreamHandler()
        ch.setLevel(logging.DEBUG)
        formatter = logging.Formatter("%(asctime)s - %(name)s - %(levelname)s - %(message)s")
        ch.setFormatter(formatter)
        logger.addHandler(ch)
        self._logger = logger
        self._logger.info("Hello")

        # List of socket_id of running student containers, and a lock protecting
        # from concurrent accesses to the list.
        self.running_student_container = None
        self.lock = threading.Lock()
        
        # A token to authenticate critical internal messages.
        self.token = secrets.token_bytes(64)

        # The internal ctrl channel.
        self.intern = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        # The ctrl channel towards the agent.
        self.agent = None

        # Whether we run commands as root in the containers.
        self.run_as_root = False

        self._loop = asyncio.new_event_loop()
        # A future to gracefully close the processing loop.
        self.on_close = self._loop.create_future()
        self._loop.run_until_complete(self.serve())

    def copy_tree(self, src, dst, symlinks=False, ignore=None):
        """ Custom copy tree to allow to copy into existing directories """
        for item in os.listdir(src):
            s = os.path.join(src, item)
            d = os.path.join(dst, item)
            if os.path.isdir(s):
                shutil.copytree(s, d, symlinks, ignore)
            else:
                shutil.copy2(s, d)

    def set_directory_rights(self, path):
        os.chmod(path, 0o777)
        os.chown(path, 4242, 4242)
        for root, dirs, files in os.walk(path):
            for d in dirs:
                os.chmod(os.path.join(root, d), 0o777)
                os.chown(os.path.join(root, d), 4242, 4242)
            for f in files:
                os.chmod(os.path.join(root, f), 0o777)
                os.chown(os.path.join(root, f), 4242, 4242)

    def b64tararchive(self):
        with tarfile.open('/tmp/archive.tgz', "w:gz") as tar:
            tar.add('/archive/', arcname='/')

        with open('/tmp/archive.tgz', "rb") as tar:
            encoded_string = base64.b64encode(tar.read())

        return encoded_string.decode('utf-8')

    async def serve(self):
        self._logger.info("Starting serve")

        # Processes channel.
        sk = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sk.bind(GRADING_CONTAINER_SK)
        sk.listen()
        server = await self._loop.create_unix_server(
            lambda: HandleInternalMessages(self),
            sock=sk,
        )

        # Allow to communicate with myself.
        self.intern.connect(GRADING_CONTAINER_SK)

        # Start ctrl channel with Agent.
        (sk, _) = await self._loop.create_connection(
            lambda: HandleAgentMessages(self),
            host=agent_ip,
            port=GRADING_CONTAINER_TCP_PORT
        )

        self.running_student_container = {}  # socket_id : addr

        self._logger.info("Serving...")

        try:
            await self.on_close
            self._logger.info("Closing container.")
            self.intern.close()
            server.close()
            await server.wait_closed()
            sk.close()
        except (asyncio.CancelledError, KeyboardInterrupt):
            return
        except Exception:
            self._logger.exception("An exception occured while serving")
        finally:
            os.unlink(GRADING_CONTAINER_SK)

